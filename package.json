{
  "name": "ja-pitch-accent",
  "version": "1.1.1",
  "description": "Pitch accent lookup and HTML formatting extracted from 10ten Japanese Reader",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && cp -R data dist/ && chmod 755 dist/bin/cli.js",
    "build-data": "node --experimental-strip-types scripts/build-dataset.ts",
    "main": "node --experimental-strip-types bin/cli.ts",
    "prepack": "pnpm run build",
    "test": "node --experimental-strip-types --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json"
  },
  "keywords": [
    "japanese",
    "pitch-accent",
    "kana",
    "dictionary"
  ],
  "author": "Jo Liss",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/joliss/ja-pitch-accent.git"
  },
  "type": "module",
  "engines": {
    "node": "24.14.1"
  },
  "bin": {
    "ja-pitch-accent": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
